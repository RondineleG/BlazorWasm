@page "/login"
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="auth-container">
    <div class="auth-box">
        <h2>🔐 Login</h2>

        <form @onsubmit="HandleLogin">
            <div class="form-group">
                <label>Username</label>
                <input type="text" @bind="username" placeholder="Enter username" />
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" @bind="password" placeholder="Enter password" />
            </div>

            @if (!string.IsNullOrEmpty(error))
            {
                <div class="error">@error</div>
            }

            <button type="submit" disabled="@loading">
                @(loading ? "Logging in..." : "Login")
            </button>
        </form>

        <div class="auth-link">
            Don't have account? <a href="register">Register</a>
        </div>
    </div>
</div>

@code {
    private string username = "";
    private string password = "";
    private string error = "";
    private bool loading = false;

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password))
        {
            error = "Please fill all fields";
            return;
        }

        loading = true;
        error = "";

        try
        {
            var response = await Http.PostAsJsonAsync("http://172.245.152.43:1408/api/auth/login",
                new { Username = username, Password = password });

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<AuthResponse>();
                if (result is not null)
                {
                    await JS.InvokeVoidAsync("localStorage.setItem", "token", result.Token);
                    await JS.InvokeVoidAsync("localStorage.setItem", "username", result.Username);
                    Nav.NavigateTo("terminal");
                }
            }
            else
            {
                error = "Invalid credentials";
            }
        }
        catch (Exception ex)
        {
            error = $"Connection error: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    record AuthResponse(string Token, int ExpiresIn, string Username);
}